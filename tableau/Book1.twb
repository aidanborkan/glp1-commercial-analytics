      <aliases enabled='yes' />
      <column caption='Cost Per Claim' datatype='real' name='[Calculation_0284227861438464]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_drug_cost]) / SUM([total_claims])' />
      </column>
      <column caption='GLP-1 Drug Market Share Within States' datatype='real' name='[Calculation_0284227863998467]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_drug_cost]) &#13;&#10;/&#13;&#10;SUM({ FIXED [prscrbr_state_abrvtn] : SUM([total_drug_cost]) })' />
      </column>
      <column caption='Cost per Claim' datatype='real' name='[Calculation_0543989317304321]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_drug_cost]) / SUM([total_claims])' />
      </column>
      <column caption='Claims per Provider' datatype='real' name='[Calculation_0543989317464066]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_claims]) / SUM([provider_count])' />
      </column>
      <column caption='Spend per Provider' datatype='real' name='[Calculation_0543989317550083]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_drug_cost]) / SUM([provider_count])' />
      </column>
      <column caption='Market Opportunity Index' datatype='real' name='[Calculation_0543989377503236]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([provider_count]) / AVG([total_claims])' />
      </column>
      <column caption='Commercial Opportunity Score' datatype='real' name='[Calculation_0543989385920518]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;[Calculation_0543989317550083] * 0.4&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;[Calculation_0543989317464066] * 0.3&#13;&#10;)&#13;&#10;+&#13;&#10;(&#13;&#10;SUM([provider_count]) * 0.3&#13;&#10;)' />
      </column>
